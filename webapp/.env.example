# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Supabase (Production Backend) ---
# Replace with your project details from Supabase Dashboard (Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-is-private
SUPABASE_ANON_KEY=your-anon-key-is-safe-for-public

# --- Storage ---
# Options: 'local', 'supabase'
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data
SUPABASE_BUCKET=adhi-assets

# --- Sarvam AI (Transcription) ---
# Get your key at https://www.sarvam.ai/
SARVAM_API_KEY=YOUR_SARVAM_API_KEY_HERE
SARVAM_API_URL=https://api.sarvam.ai/v1/transcribe

# --- Redis / Celery (Task Queue) ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_DEFAULT_QUEUE=cpu_tasks

# --- Database (Metadata) ---
# For local development: sqlite:///./data/metadata.db
# For Supabase: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=sqlite:///./data/metadata.db

# --- Embeddings & LLM (The Brain) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=gemini

# !! SET YOUR GOOGLE API KEY !!
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# --- Frontend (WebApp) ---
# Used by Next.js in /webapp
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- App Tuning ---
VIDEO_FRAME_INTERVAL_SEC=7
TRANSCRIPT_CHUNK_SEC=30
BATCH_EMBED_SIZE=16