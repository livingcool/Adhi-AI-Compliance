# ==================== SECRETS & SENSITIVE DATA ====================
# Environment variables and secrets
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
*.cert
*.ca-bundle
secrets.json
config.local.json
settings.local.json

