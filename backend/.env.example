# Backend Environment Configuration

# --- Core App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Storage ---
STORAGE_BACKEND=local
DATABASE_URL=sqlite:///./data/metadata.db

# --- LLM Provider Selection ---
# Options: "gemini", "openai", "huggingface"
LLM_PROVIDER=huggingface

# --- HuggingFace Configuration (DEFAULT FOR OPEN-SOURCE) ---
# Get your token at: https://huggingface.co/settings/tokens
# Optional but recommended for higher rate limits (free tier: 30K tokens/day)
HF_TOKEN=

# Models to use (defaults work well, can be changed)
HF_MODEL_CHAT=mistralai/Mixtral-8x7B-Instruct-v0.1
HF_MODEL_EMBED=sentence-transformers/all-MiniLM-L6-v2

# --- Gemini Configuration (LEGACY, keep for fallback) ---
GOOGLE_API_KEY=

# --- OpenAI Configuration (ALTERNATIVE) ---
OPENAI_API_KEY=

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Supabase (for persistent vector storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Sarvam AI (for audio transcription) ---
SARVAM_API_KEY=
SARVAM_API_URL=https://api.sarvam.ai/stt

# --- Redis/Celery ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- File Upload Limits ---
MAX_UPLOAD_SIZE_MB=500
UPLOAD_CHUNK_SIZE_BYTES=1048576

# --- Processing Settings ---
VIDEO_FRAME_INTERVAL_SEC=7
TRANSCRIPT_CHUNK_SEC=30
BATCH_EMBED_SIZE=16
