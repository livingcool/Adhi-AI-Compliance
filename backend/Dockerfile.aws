# ── Stage: runtime (AWS-optimised) ───────────────────────────────────────────
# Uses requirements.aws.txt which strips sentence-transformers/torch/faiss
# (~800 MB vs ~6 GB with full requirements.txt)
# Embeddings → Amazon Bedrock Titan Text V2  |  LLM → Claude 3.5 Sonnet
FROM python:3.12-slim

# System dependencies
#   libgl1 + libglib2.0-0 → OpenCV
#   ffmpeg                 → audio/video processing
#   poppler-utils          → pdf2image
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    ffmpeg \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy and install Python dependencies first (layer cache)
COPY requirements.aws.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.aws.txt

# Copy application source
COPY . .

# Create data directory for local storage fallback
RUN mkdir -p data

EXPOSE 8080

# Production: 4 workers
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "4"]
